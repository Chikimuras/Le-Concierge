{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, org_id, email AS \"email: Email\",\n                   role AS \"role: Role\", invited_by,\n                   expires_at, created_at\n              FROM organization_invites\n             WHERE org_id = $1\n               AND accepted_at IS NULL\n               AND cancelled_at IS NULL\n               AND expires_at > now()\n             ORDER BY created_at DESC\n            ",
