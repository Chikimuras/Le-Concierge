{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT o.id   AS org_id,\n                   o.slug AS org_slug,\n                   o.name AS org_name,\n                   om.role AS \"role: Role\"\n            FROM organization_members om\n            JOIN organizations o ON o.id = om.org_id\n            WHERE om.user_id = $1\n            ORDER BY o.created_at ASC\n            ",
