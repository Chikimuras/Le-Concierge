  "query": "\n            SELECT o.id AS org_id,\n                   om.role AS \"role: Role\"\n              FROM organizations o\n              JOIN organization_members om\n                ON om.org_id = o.id\n               AND om.user_id = $1\n             WHERE o.slug = $2\n            ",
