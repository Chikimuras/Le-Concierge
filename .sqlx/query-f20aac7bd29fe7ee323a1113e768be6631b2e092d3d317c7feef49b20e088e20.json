  "query": "\n            SELECT id, org_id, slug, name, timezone,\n                   address_line1, address_line2, city, postal_code, country,\n                   bedrooms, max_guests, notes,\n                   created_at, updated_at\n              FROM properties\n             WHERE org_id = $1\n               AND deleted_at IS NULL\n             ORDER BY updated_at DESC\n            ",
