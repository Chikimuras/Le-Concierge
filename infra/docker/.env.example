# Development credentials for the docker compose stack.
#
# Copy to `infra/docker/.env` to override. The `.env` file is gitignored;
# this example file is the committed reference.
#
# ⚠️  These values are **dev only**. They are intentionally weak. Production
# secrets come from Docker secrets / SOPS+age per CLAUDE.md §3.3.

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=le_concierge
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=le_concierge_dev

# --- MinIO -----------------------------------------------------------------
# Must be at least 8 characters (MinIO requirement).
MINIO_ROOT_USER=minio_dev
MINIO_ROOT_PASSWORD=minio_dev_secret
