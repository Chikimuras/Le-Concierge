# Copy to `.env` and tailor to your local setup. Never commit `.env`.
#
# All variables are prefixed with `APP_`. Nested TOML keys use `__` as the
# separator (e.g. `http.bind` → `APP_HTTP__BIND`).

# --- HTTP --------------------------------------------------------------------
# APP_HTTP__BIND=127.0.0.1:3000
# APP_HTTP__REQUEST_TIMEOUT_SECS=30
# APP_HTTP__PUBLIC_BASE_URL=http://localhost:3000

# --- Database ----------------------------------------------------------------
# Matches the defaults in infra/docker/.env.example. For a compose stack
# launched via `just compose-up`, this URL reaches postgres via the host
# port-forward (127.0.0.1:5432). Inside the api container itself, set this
# to `postgres://…@postgres:5432/…` (done in compose.yaml).
APP_DATABASE__URL=postgres://le_concierge:dev_password_change_me@127.0.0.1:5432/le_concierge_dev
# APP_DATABASE__MAX_CONNECTIONS=10
# APP_DATABASE__MIN_CONNECTIONS=0
# APP_DATABASE__STATEMENT_TIMEOUT_SECS=5

# --- Telemetry --------------------------------------------------------------
# `pretty` for local dev, `json` in every non-dev environment (CLAUDE.md §5).
APP_TELEMETRY__FORMAT=pretty
# Tracing EnvFilter — adjust per module as needed.
APP_TELEMETRY__FILTER=api=debug,tower_http=info,sqlx=warn,warn
# APP_TELEMETRY__SERVICE_NAME=api

# --- CORS -------------------------------------------------------------------
# Array overrides from env must use JSON syntax (figment env provider treats
# values as opaque strings). Empty array disables CORS. Never include `*`
# with credentials (OWASP ASVS 14.5.3). For env-specific arrays, prefer
# overlaying a TOML file via APP_CONFIG_FILE.
#
# In dev, you do NOT need CORS if you hit the API through the Vite proxy
# (http://127.0.0.1:5173/api/*). Only enable this when the web app calls
# the API on a different origin (e.g. curl from another port, a mobile
# simulator, or production with split domains).
# APP_CORS__ALLOWED_ORIGINS=["http://localhost:5173"]

# --- Override config file path (optional) -----------------------------------
# APP_CONFIG_FILE=./config/local.toml
