# Copy to `.env.local` (or `.env.development.local`) and adjust.
# Only variables prefixed `VITE_` are exposed to client-side code.

# Absolute URL to the API. In dev this is left unset — the Vite proxy
# handles `/api/*` → http://127.0.0.1:3000 so no CORS is involved.
# In prod, point to the public API URL (same origin preferred).
# VITE_API_BASE_URL=https://api.leconcierge.fr
